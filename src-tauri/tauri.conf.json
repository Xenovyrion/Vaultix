{
  "productName": "Vaultix",
  "version": "1.0.2",
  "identifier": "io.github.lordluffy.vaultix",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vaultix",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/Vaultix.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyNDI2MzVGMUQ4MDdBMjQKUldRa2VvQWRYMk5DZ2p2bXl0R2xQZHhpV1JiQmR1UkgwREphYzd5cW5HRlBEd3FSRXpwSy9oWTQK",
      "endpoints": [
        "https://github.com/LordLuffy/Vaultix/releases/latest/download/latest.json"
      ]
    }
  }
}
